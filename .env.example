# Verath — copy to .env and fill in values

# ── LLM & embeddings (at least one provider required) ───────────────────────
GROQ_API_KEY=                    # https://console.groq.com
GEMINI_API_KEY=                  # https://aistudio.google.com
LLM_PROVIDER=groq                # groq | gemini
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-1.5-flash
EMBED_PROVIDER=gemini

# ── Speech-to-text ───────────────────────────────────────────────────────────
WHISPER_MODEL=base               # tiny | base | small | medium | large
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENV=development                  # development | production
DEFAULT_RECORD_SECONDS=10
ALLOW_CORS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# ── Storage ────────────────────────────────────────────────────────────────────
VECTOR_DB_PATH=data/chroma_db
VOICE_DB_PATH=data/voices.pkl

# ── MongoDB (required) ───────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=verath

# ── Security (required — min 32 characters) ──────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15

# ── Audio processing ───────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=int16
MAX_AUDIO_CHUNK_SIZE=30
SILENCE_THRESHOLD=0.01
MIN_TRANSCRIPTION_LENGTH=5

# ── Memory defaults ────────────────────────────────────────────────────────────
MAX_MEMORY_RESULTS=100
MEMORY_IMPORTANCE_THRESHOLD=0.6

# ── UI (web dashboard) ─────────────────────────────────────────────────────────
THEME=dark
AUTO_REFRESH_INTERVAL=30
