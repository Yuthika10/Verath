# ── SECURITY: NEVER COMMIT THIS FILE TO VERSION CONTROL ──
# These are production environment variables for Verath

# Environment
ENV=production

# Database - Use MongoDB Atlas for production
# SECURITY: Replace with your actual Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/Verath?retryWrites=true&w=majority
DATABASE_NAME=Verath_prod

# Security - SECRET_KEY must be at least 32 characters for HS256
# SECURITY: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_HERE

# Vector Database
VECTOR_DB_PATH=./data/chromadb

# Voice Profiles
VOICE_DB_PATH=./data/voice_profiles.json

# Ollama - Use remote Ollama instance in production
OLLAMA_URL=http://your-ollama-instance:11434

# CORS - Comma-separated list of allowed origins
# SECURITY: Replace with your actual frontend domains
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Logging
LOG_LEVEL=WARNING
